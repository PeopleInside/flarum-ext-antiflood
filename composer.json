{
    "name": "peopleinside/flarum-ext-antiflood",
    "description": "Estensione Flarum per prevenire il flooding di topic/post e limitare le approvazioni in sospeso.",
    "type": "flarum-extension",
    "keywords": ["flarum", "antiflood", "approval"],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Peopleinside",
            "homepage": "https://github.com/PeopleInside/flarum-ext-antiflood"
        }
    ],
    "support": {
        "issues": "https://github.com/PeopleInside/flarum-ext-antiflood/issues",
        "forum": "https://github.com/PeopleInside/flarum-ext-antiflood/discussions",
        "security": "https://github.com/PeopleInside/flarum-ext-antiflood/security/policy"
    },
    "require": {
        "php": "^8.0",
        "flarum/core": "^1.0 || ^2.0"
    },
    "require-dev": {
        "flarum/testing": "^1.0 || ^2.0",
        "pestphp/pest": "^1.0 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "Peopleinside\\AntiFlood\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "AntiFlood",
            "icon": {
                "name": "fas fa-shield-alt"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
